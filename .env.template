# Upstox Intraday Trading Bot - Environment Configurations
# Copy this file to .env and fill in your actual credentials

# Upstox API Credentials
UPSTOX_API_KEY=your_api_key_here
UPSTOX_API_SECRET=your_api_secret_here
UPSTOX_REDIRECT_URI=https://127.0.0.1:5000/callback

# Current Access Token (automatically obtained and updated by OAuth callback)
UPSTOX_ACCESS_TOKEN=your_access_token_here

# Proxy URL (optional, if you use a rotating proxy zone)
PROXY_URL=

# Anthropic API key for the Claude-powered lesson/proposal engine
ANTHROPIC_API_KEY=

# Required to actually start in live mode (Section 0 rule 1). Leave blank to stay in paper mode.
LIVE_TRADING_CONFIRMED=
